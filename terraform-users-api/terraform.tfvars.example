# terraform-users-api/terraform.tfvars.example
aws_region     = "ap-southeast-1"
app_name       = "myapp"
environment    = "dev"
tfstate_bucket = "myapp-tfstate"

github_repo   = "alleoko/users-api"
github_branch = "main"

task_cpu      = 256
task_memory   = 512
desired_count = 2
min_capacity  = 1
max_capacity  = 10

db_name     = "appdb"
db_username = "admin"
